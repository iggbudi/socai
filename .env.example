# Database PostgreSQL
DB_USER=
DB_PASSWORD=
DB_NAME=socai
DB_HOST=127.0.0.1
DB_PORT=5432

# Brave Search API Key (untuk AI web search)
BRAVE_API_KEY=

# AI model fallback web + default Telegram (format: provider/model-id)
AI_MODEL=xiaomi/mimo-v2.5-pro
AI_MODEL_FALLBACKS=xiaomi/mimo-v2.5,opencode/deepseek-v4-flash-free

# Override khusus Telegram bot. Xiaomi MiMo memakai XIAOMI_API_KEY.
# Provider alternatif Xiaomi Token Plan:
# xiaomi-token-plan-cn, xiaomi-token-plan-ams, xiaomi-token-plan-sgp
TELEGRAM_AI_MODEL=xiaomi/mimo-v2.5-pro
TELEGRAM_AI_MODEL_FALLBACKS=xiaomi/mimo-v2.5,opencode/deepseek-v4-flash-free
XIAOMI_API_KEY=
XIAOMI_TOKEN_PLAN_CN_API_KEY=
XIAOMI_TOKEN_PLAN_AMS_API_KEY=
XIAOMI_TOKEN_PLAN_SGP_API_KEY=

# Session Secret (random string, generate baru untuk production)
SESSION_SECRET=

# Telegram Bot Token (dari @BotFather)
TELEGRAM_BOT_TOKEN=
# Fallback alias opsional jika diperlukan
BOT_TOKEN=
TELEGRAM_TOKEN=

# Cloudinary (opsional, untuk upload gambar konten marketing dari Telegram)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Repliz (opsional, untuk penjadwalan konten pemasaran ke Threads)
REPLIZ_API_KEY=
REPLIZ_SECRET=
REPLIZ_ACCOUNT_ID=
REPLIZ_BASE_URL=https://api.repliz.com
REPLIZ_SYNC_INTERVAL_MS=300000

# Server Port
PORT=3010
